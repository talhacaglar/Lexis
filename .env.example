# Lexis — Örnek Environment Dosyası
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# cp .env.example .env

# Google Gemini API Anahtarı (gerekli)
# https://aistudio.google.com/app/apikey adresinden alabilirsiniz.
GEMINI_API_KEY=your_gemini_api_key_here

# Veritabanı dosyasının konumu (isteğe bağlı)
# Varsayılan: kullanıcı ana dizininde ~/.lexis/lexis.db
# DATABASE_PATH=/path/to/your/lexis.db

# Loglama seviyesi (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
